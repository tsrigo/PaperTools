# PaperTools SJTU configuration template
# Copy to .env and put the real key in OPENAI_API_KEY. Do not commit .env.

OPENAI_BASE_URL=https://models.sjtu.edu.cn/api/v1/
OPENAI_API_KEY=replace_with_your_secret_key

# Available SJTU model_id values observed for this deployment:
# minimax, glm, qwen, deepseek-chat, deepseek-reasoner
MODEL=minimax
FILTER_MODEL=qwen
CLUSTER_MODEL=glm

# Keep summary on SJTU unless you intentionally add Prism/ModelScope keys.
SUMMARY_OPENAI_API_KEY=${OPENAI_API_KEY}
SUMMARY_OPENAI_BASE_URL=https://models.sjtu.edu.cn/api/v1/
SUMMARY_MODEL=minimax
SUMMARY_SJTU_OPENAI_API_KEY=${OPENAI_API_KEY}
SUMMARY_SJTU_OPENAI_BASE_URL=https://models.sjtu.edu.cn/api/v1/
SUMMARY_MODEL_CHAIN=sjtu:minimax,sjtu:glm,sjtu:qwen,sjtu:deepseek-chat,sjtu:deepseek-reasoner

# The SJTU gateway is a shared service; low concurrency beats random manual reruns.
FILTER_MAX_WORKERS=2
SUMMARY_MAX_WORKERS=1
PAPERTOOLS_FILTER_RPM=6
PAPERTOOLS_FILTER_LLM_TIMEOUT=120
PAPERTOOLS_FILTER_LLM_MAX_RETRIES=3
PAPERTOOLS_OPENAI_TIMEOUT=120
PAPERTOOLS_OPENAI_SDK_MAX_RETRIES=2
PAPERTOOLS_RETRY_MAX_DELAY_SECONDS=60
PAPERTOOLS_OPENAI_TRUST_ENV=false

# Rolling catch-up window for daily cron.
PAPERTOOLS_DAILY_WINDOW_DAYS=4
PAPERTOOLS_DAILY_MAX_ATTEMPTS=3
PAPERTOOLS_AUTO_COMMIT=1
PAPERTOOLS_AUTO_PUSH=0

# Optional: keep ReviewGrounder disabled unless you have the right provider/key.
REVIEWGROUNDER_ENABLED=false
