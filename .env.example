# API Configuration (required)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://your-api-url/v1/
MODEL=your_model_name
FILTER_MODEL=qwen
CLUSTER_MODEL=qwen
# Optional comma-separated fallback models for clustering. Bare SJTU aliases are
# auto-normalized when CLUSTER_OPENAI_BASE_URL points at OpenRouter.
# PAPERTOOLS_CLUSTER_MODEL_CHAIN=qwen,deepseek-chat,minimax
# CLUSTER_OPENAI_API_KEY=your_cluster_api_key_here
# CLUSTER_OPENAI_BASE_URL=https://your-api-url/v1/

# Summary generation uses a separate provider/model by default.
# Keep filtering on FILTER_MODEL; set this token locally, never commit a real one.
SUMMARY_OPENAI_API_KEY=your_optional_modelscope_token_here
SUMMARY_OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
SUMMARY_MODEL=minimax
SUMMARY_MODEL_CHAIN=prism:gpt-5.5,sjtu:minimax,sjtu:glm,sjtu:qwen,sjtu:deepseek-reasoner,sjtu:deepseek-chat
SUMMARY_PRISM_OPENAI_API_KEY=your_prism_token_here
SUMMARY_PRISM_OPENAI_BASE_URL=https://ai.prism.uno/v1
SUMMARY_PRISM_RPM=5
SUMMARY_PRISM_REASONING_EFFORT=xhigh
SUMMARY_PRISM_WINDOW_SECONDS=300
SUMMARY_PRISM_WINDOW_SAFETY_REQUESTS=1
SUMMARY_PRISM_429_COOLDOWN_SECONDS=300
SUMMARY_SJTU_OPENAI_API_KEY=your_sjtu_token_here
SUMMARY_SJTU_OPENAI_BASE_URL=https://models.sjtu.edu.cn/api/v1/
SUMMARY_SJTU_RPM=2
SUMMARY_SJTU_WINDOW_SECONDS=300
SUMMARY_SJTU_WINDOW_SAFETY_REQUESTS=1
SUMMARY_SJTU_429_COOLDOWN_SECONDS=300
SUMMARY_CONTENT_CHAR_LIMIT=200000
SUMMARY_MAX_WORKERS=5

# ReviewGrounder reviewer replacing the old research-value prompt.
REVIEWGROUNDER_ENABLED=false
REVIEWGROUNDER_PATH=vendor/ReviewGrounder
# Defaults to SUMMARY_PRISM_OPENAI_API_KEY / SUMMARY_PRISM_OPENAI_BASE_URL, then OPENAI_*.
# REVIEWGROUNDER_API_KEY=your_reviewgrounder_api_key_here
# REVIEWGROUNDER_BASE_URL=https://ai.prism.uno/v1
REVIEWGROUNDER_MODEL=gpt-5.5
REVIEWGROUNDER_REASONING_EFFORT=xhigh
REVIEWGROUNDER_MAX_OUTPUT_TOKENS=16384
REVIEWGROUNDER_MAX_RELATED_PAPERS=1
REVIEWGROUNDER_RPM=5
REVIEWGROUNDER_MAX_PARALLEL_SUMMARIES=1
REVIEWGROUNDER_JSON_TOOL_RETRIES=1
REVIEWGROUNDER_ENABLE_WEB_FALLBACK=true
REVIEWGROUNDER_REVIEW_FORMAT=ai_researcher
REVIEWGROUNDER_REFINER_REVIEW_FORMAT=detailed_gradio

# Optional prestige hard filter settings
PRESTIGE_ENABLED=true
PAPERTOOLS_TOPIC_HEURISTIC_BYPASS_PRESTIGE=false
PAPERTOOLS_PRESTIGE_AFFILIATION_FETCH_ENABLED=true
PRESTIGE_CONTEXT_CHARS=16000
FILTER_MAX_WORKERS=5
PAPERTOOLS_FILTER_LLM_TIMEOUT=45
PAPERTOOLS_FILTER_LLM_MAX_RETRIES=1
PAPERTOOLS_FILTER_RPM=8
PAPERTOOLS_FILTER_EXTRACT_CHAIN=docling,pymupdf4llm,jina
PAPERTOOLS_TOPIC_HEURISTIC_TOPIC_BYPASS_MIN_SCORE=30
PAPERTOOLS_FILTER_SUSPICIOUS_ZERO_MIN_INPUT=500
PAPERTOOLS_FILTER_SUSPICIOUS_ZERO_MIN_PREFILTERED=100
# OpenAI-compatible API clients ignore process-wide proxy env by default.
# Set true only if those API endpoints must go through http_proxy/https_proxy.
PAPERTOOLS_OPENAI_TRUST_ENV=false
# Optional comma-separated fallback models for the topic/prestige filter. Bare SJTU
# aliases like qwen/deepseek-chat are auto-normalized when OPENAI_BASE_URL points
# at OpenRouter, where provider-prefixed model IDs are required.
# PAPERTOOLS_FILTER_MODEL_CHAIN=deepseek-chat,qwen,minimax

# Webhook notification (optional) — Pumble, Slack, Feishu, Discord etc.
WEBHOOK_URL=

# Daily cron wrapper safeguards (optional)
PAPERTOOLS_KILL_STALE=0
PAPERTOOLS_COMMIT_ON_PIPELINE_FAILURE=0
PAPERTOOLS_DAILY_WINDOW_DAYS=4
# PAPERTOOLS_DAILY_START_DATE=2026-04-28
# PAPERTOOLS_DAILY_END_DATE=2026-04-30

# Optional: document extraction provider chain
DOCUMENT_EXTRACTOR_CHAIN=docling,pymupdf4llm,jina
DOCUMENT_EXTRACT_OCR_MODE=auto
DOCUMENT_EXTRACT_REMOTE_FALLBACK=true

# Optional: Jina API Token (remote fallback only)
# JINA_API_TOKEN=your_jina_token_here
